# VS Code Extension — Ignore files not needed in the VSIX package
.vscode/**
src/**
out/**
node_modules/**
playwright/**
scripts/**
.playwright-cache/**
playwright.config.ts
.vscode-test/**
coverage/**
playwright-results/**
tsconfig.json
webpack.config.js
*.map
.gitignore
*.vsix

# Exclude OSGi runtime cache (regenerated on first launch)
server/**/org.eclipse.osgi/**
server/**/org.eclipse.equinox.app/**

# Keep the server directory, syntaxes, and license
!server/**
!syntaxes/**
!dist/**
!language-configuration.json
!LICENSE
