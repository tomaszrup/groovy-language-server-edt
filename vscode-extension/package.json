{
    "name": "groovy-spock-support",
    "displayName": "Language Support for Groovy",
    "description": "Rich Groovy language support powered by Eclipse/groovy-eclipse — completion, diagnostics, hover, go-to-definition, references, rename, and more.",
    "version": "1.2.37",
    "publisher": "TomaszRup",
    "license": "EPL-2.0",
    "homepage": "https://github.com/tomaszrup/groovy-language-server-edt",
    "repository": {
        "type": "git",
        "url": "https://github.com/tomaszrup/groovy-language-server-edt.git"
    },
    "bugs": {
        "url": "https://github.com/tomaszrup/groovy-language-server-edt/issues"
    },
    "icon": "./images/groovy.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Snippets"
    ],
    "keywords": [
        "groovy",
        "gradle",
        "grails",
        "language server",
        "LSP"
    ],
    "extensionDependencies": [
        "redhat.java"
    ],
    "extensionKind": [
        "workspace"
    ],
    "activationEvents": [
        "workspaceContains:**/*.groovy"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "groovy",
                "aliases": [
                    "Groovy",
                    "groovy"
                ],
                "extensions": [
                    ".groovy",
                    ".gvy",
                    ".gy",
                    ".gsh",
                    ".gradle"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "groovy",
                "scopeName": "source.groovy",
                "path": "./syntaxes/groovy.tmLanguage.json",
                "tokenTypes": {
                    "comment": "comment",
                    "string.quoted.single.groovy": "string",
                    "string.quoted.triple.single.groovy": "string",
                    "string.quoted.double.groovy": "string",
                    "string.quoted.triple.double.groovy": "string",
                    "string.quoted.slashy.groovy": "string",
                    "string.quoted.dollar-slashy.groovy": "string"
                },
                "unbalancedBracketScopes": [
                    "comment",
                    "string.quoted.single.groovy",
                    "string.quoted.triple.single.groovy",
                    "string.quoted.double.groovy - meta.interpolation.groovy",
                    "string.quoted.triple.double.groovy - meta.interpolation.groovy",
                    "string.quoted.slashy.groovy - meta.interpolation.groovy",
                    "string.quoted.dollar-slashy.groovy - meta.interpolation.groovy"
                ]
            },
            {
                "scopeName": "source.groovy.spock-feature-name.injection",
                "path": "./syntaxes/groovy-spock-feature-name.injection.json",
                "injectTo": [
                    "source.groovy"
                ],
                "tokenTypes": {
                    "string.quoted.single.groovy": "string",
                    "string.quoted.double.groovy": "string"
                },
                "unbalancedBracketScopes": [
                    "string.quoted.single.groovy",
                    "string.quoted.double.groovy - meta.interpolation.groovy"
                ]
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "typeKeyword",
                "description": "Declaration and inheritance keywords like class, interface, enum, trait, extends, and implements."
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "groovy",
                "scopes": {
                    "struct": [
                        "entity.name.type.class.groovy"
                    ],
                    "keyword": [
                        "keyword.control.groovy"
                    ],
                    "typeKeyword": [
                        "storage.modifier",
                        "storage.modifier.groovy"
                    ]
                }
            }
        ],
        "configuration": {
            "title": "Groovy",
            "properties": {
                "groovy.java.home": {
                    "type": "string",
                    "default": null,
                    "description": "Path to the JDK installation used to run the Groovy language server. Requires JDK 21 or later. If not set, uses the JAVA_HOME environment variable.",
                    "scope": "machine-overridable"
                },
                "groovy.ls.vmargs": {
                    "type": "string",
                    "default": "-Xmx2G",
                    "description": "JVM arguments for the language server. Default is -Xmx2G. For large workspaces with 50+ projects, consider -Xmx3G or -Xmx4G.",
                    "scope": "machine-overridable"
                },
                "groovy.ls.logLevel": {
                    "type": "string",
                    "enum": [
                        "error",
                        "warning",
                        "info"
                    ],
                    "default": "error",
                    "description": "Controls the verbosity of the Groovy language server's internal logging. Messages below the selected level are suppressed.",
                    "scope": "window"
                },
                "groovy.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the Groovy language server.",
                    "scope": "window"
                },
                "groovy.format.settingsUrl": {
                    "type": "string",
                    "default": null,
                    "markdownDescription": "Path to an Eclipse formatter profile XML file. Supports absolute paths, workspace-relative paths, and `file://` URIs. This is the same XML format exported by Eclipse IDE's **Java > Code Style > Formatter** preferences. If unset, the language server uses its bundled IntelliJ-style default profile.",
                    "scope": "resource"
                },
                "groovy.format.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable the Groovy document formatter.",
                    "scope": "window"
                },
                "groovy.inlayHints.variableTypes.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show inferred type hints for variables declared with def.",
                    "scope": "window"
                },
                "groovy.inlayHints.parameterNames.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show parameter name hints at method and constructor call sites.",
                    "scope": "window"
                },
                "groovy.inlayHints.closureParameterTypes.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show inferred types for closure parameters.",
                    "scope": "window"
                },
                "groovy.inlayHints.methodReturnTypes.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show inferred return type hints for methods declared with def.",
                    "scope": "window"
                },
                "groovy.ls.requestPoolSize": {
                    "type": "integer",
                    "default": 0,
                    "minimum": 0,
                    "markdownDescription": "Max threads for the **fast** (interactive) pool handling hover, completion, definition, semanticTokens, codeAction, etc. `0` = auto (`max(4, cpus)`). The fast pool is isolated from background work so interactive requests are never starved.",
                    "scope": "machine-overridable"
                },
                "groovy.ls.requestQueueSize": {
                    "type": "integer",
                    "default": 64,
                    "minimum": 16,
                    "markdownDescription": "Bounded queue capacity for the fast pool. Interactive requests should fail fast rather than wait in a deep queue.",
                    "scope": "machine-overridable"
                },
                "groovy.ls.backgroundPoolSize": {
                    "type": "integer",
                    "default": 0,
                    "minimum": 0,
                    "markdownDescription": "Max threads for the **background** pool handling decorative features (documentSymbol, codeLens, foldingRange, inlayHint). `0` = auto (`max(3, cpus-1)`). These features render in the gutter/outline and tolerate higher latency.",
                    "scope": "machine-overridable"
                },
                "groovy.ls.backgroundQueueSize": {
                    "type": "integer",
                    "default": 128,
                    "minimum": 16,
                    "markdownDescription": "Bounded queue capacity for the background pool. A larger queue is acceptable here since background requests are not user-blocking.",
                    "scope": "machine-overridable"
                }
            }
        },
        "commands": [
            {
                "command": "groovy.triggerSuggestAndSignatureHelp",
                "title": "Groovy: Trigger Completion And Signature Help"
            },
            {
                "command": "groovy.restartServer",
                "title": "Groovy: Restart Language Server"
            },
            {
                "command": "groovy.showOutputChannel",
                "title": "Groovy: Show Output Channel"
            }
        ],
        "keybindings": [
            {
                "command": "groovy.triggerSuggestAndSignatureHelp",
                "key": "ctrl+space",
                "when": "editorTextFocus && editorLangId == groovy"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "prepare:playwright-server": "node ./scripts/preparePlaywrightServer.js",
        "compile": "webpack --mode production",
        "watch": "webpack --mode development --watch",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "lint": "npm run typecheck",
        "package": "vsce package",
        "test": "mocha --require ts-node/register --extension ts \"src/test/**/*.test.ts\"",
        "test:coverage": "node ./scripts/runCoverage.js",
        "test:playwright": "npm run prepare:playwright-server && npm run compile && playwright test",
        "test:playwright:headed": "npm run prepare:playwright-server && npm run compile && playwright test --headed"
    },
    "devDependencies": {
        "@playwright/test": "^1.59.1",
        "@types/node": "^20.0.0",
        "@types/mocha": "^10.0.10",
        "@types/mock-require": "^3.0.0",
        "@types/vscode": "^1.85.0",
        "@vscode/test-electron": "^2.5.2",
        "c8": "^10.1.3",
        "mock-require": "^3.0.3",
        "mocha": "^11.7.1",
        "sinon": "^21.0.0",
        "@types/sinon": "^17.0.4",
        "ts-node": "^10.9.2",
        "ts-loader": "^9.5.0",
        "typescript": "^5.3.0",
        "webpack": "^5.90.0",
        "webpack-cli": "^5.1.0",
        "@vscode/vsce": "^2.22.0"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    }
}
