{
    "name": "groovy-spock-support",
    "displayName": "Language Support for Groovy",
    "description": "Rich Groovy language support powered by Eclipse/groovy-eclipse — completion, diagnostics, hover, go-to-definition, references, rename, and more.",
    "version": "1.0.11",
    "publisher": "TomaszRup",
    "license": "EPL-2.0",
    "homepage": "https://github.com/tomaszrup/groovy-language-server-edt",
    "repository": {
        "type": "git",
        "url": "https://github.com/tomaszrup/groovy-language-server-edt.git"
    },
    "bugs": {
        "url": "https://github.com/tomaszrup/groovy-language-server-edt/issues"
    },
    "icon": "./images/groovy.png",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Snippets"
    ],
    "keywords": [
        "groovy",
        "gradle",
        "grails",
        "language server",
        "LSP"
    ],
    "extensionDependencies": [
        "java.redhat"
    ],
    "extensionKind": [
        "workspace"
    ],
    "activationEvents": [
        "workspaceContains:**/*.groovy"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "groovy",
                "aliases": [
                    "Groovy",
                    "groovy"
                ],
                "extensions": [
                    ".groovy",
                    ".gvy",
                    ".gy",
                    ".gsh",
                    ".gradle"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "groovy",
                "scopeName": "source.groovy",
                "path": "./syntaxes/groovy.tmLanguage.json"
            }
        ],
        "semanticTokenTypes": [
            {
                "id": "typeKeyword",
                "description": "Type declaration keywords like class, interface, enum, and trait."
            }
        ],
        "semanticTokenScopes": [
            {
                "language": "groovy",
                "scopes": {
                    "struct": [
                        "entity.name.type.class.groovy"
                    ],
                    "keyword": [
                        "keyword.control.groovy"
                    ],
                    "typeKeyword": [
                        "storage.type",
                        "storage.type.groovy"
                    ]
                }
            }
        ],
        "configuration": {
            "title": "Groovy",
            "properties": {
                "groovy.java.home": {
                    "type": "string",
                    "default": null,
                    "description": "Path to the JDK installation used to run the Groovy language server. Requires JDK 17 or later. If not set, uses the JAVA_HOME environment variable.",
                    "scope": "machine-overridable"
                },
                "groovy.ls.vmargs": {
                    "type": "string",
                    "default": "-Xmx2G",
                    "description": "JVM arguments for the language server. Default is -Xmx2G. For large workspaces with 50+ projects, consider -Xmx3G or -Xmx4G.",
                    "scope": "machine-overridable"
                },
                "groovy.ls.logLevel": {
                    "type": "string",
                    "enum": [
                        "error",
                        "warning",
                        "info"
                    ],
                    "default": "error",
                    "description": "Controls the verbosity of the Groovy language server's internal logging. Messages below the selected level are suppressed.",
                    "scope": "window"
                },
                "groovy.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the Groovy language server.",
                    "scope": "window"
                },
                "groovy.format.settingsUrl": {
                    "type": "string",
                    "default": null,
                    "markdownDescription": "Path to an Eclipse formatter profile XML file. Supports absolute paths, workspace-relative paths, and `file://` URIs. This is the same XML format exported by Eclipse IDE's **Java > Code Style > Formatter** preferences.",
                    "scope": "resource"
                },
                "groovy.format.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable/disable the Groovy document formatter.",
                    "scope": "window"
                },
                "groovy.inlayHints.variableTypes.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show inferred type hints for variables declared with def.",
                    "scope": "window"
                },
                "groovy.inlayHints.parameterNames.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show parameter name hints at method and constructor call sites.",
                    "scope": "window"
                },
                "groovy.inlayHints.closureParameterTypes.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show inferred types for closure parameters.",
                    "scope": "window"
                },
                "groovy.inlayHints.methodReturnTypes.enabled": {
                    "type": "boolean",
                    "default": true,
                    "description": "Show inferred return type hints for methods declared with def.",
                    "scope": "window"
                }
            }
        },
        "commands": [
            {
                "command": "groovy.restartServer",
                "title": "Groovy: Restart Language Server"
            },
            {
                "command": "groovy.showOutputChannel",
                "title": "Groovy: Show Output Channel"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "webpack --mode production",
        "watch": "webpack --mode development --watch",
        "lint": "eslint src/**/*.ts",
        "package": "vsce package",
        "test": "mocha --require ts-node/register --extension ts \"src/test/**/*.test.ts\""
    },
    "devDependencies": {
        "@types/node": "^20.0.0",
        "@types/mocha": "^10.0.10",
        "@types/vscode": "^1.85.0",
        "mocha": "^11.7.1",
        "sinon": "^21.0.0",
        "@types/sinon": "^17.0.4",
        "ts-node": "^10.9.2",
        "ts-loader": "^9.5.0",
        "typescript": "^5.3.0",
        "webpack": "^5.90.0",
        "webpack-cli": "^5.1.0",
        "@vscode/vsce": "^2.22.0"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    }
}